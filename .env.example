# PubMed API Configuration

# === Single API Key (optional) ===
PUBMED_API_KEY=your_pubmed_api_key_here
PUBMED_EMAIL=your_email@example.com

# === Multi-Key Pool ===
# Create api-keys.json (see api-keys.json.example)
# Overrides PUBMED_API_KEY when present
# Strategies: round-robin / failover / random

# Abstract mode: quick (1500 chars) | deep (6000 chars, needs ≥120k context)
ABSTRACT_MODE=quick

# Full-text mode: disabled | enabled | auto
FULLTEXT_MODE=disabled

# Transport: stdio (default) | streamableHttp
# MCP_TRANSPORT=stdio
# PORT=8745
