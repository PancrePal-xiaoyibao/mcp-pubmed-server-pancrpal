{
  "name": "mcp-pubmed-llm-server",
  "version": "3.0.0",
  "description": "PubMed MCP server — agentic biomedical literature search for LLMs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-pubmed-llm-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --mode=stdio",
    "start:http": "node dist/index.js --mode=streamableHttp",
    "dev": "tsx --watch src/index.ts",
    "dev:http": "tsx --watch src/index.ts --mode=streamableHttp",
    "test": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "setup": "npm install && cp .env.example .env"
  },
  "keywords": [
    "mcp",
    "pubmed",
    "llm",
    "biomedical",
    "search",
    "agent"
  ],
  "author": "PancrePal-xiaoyibao Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^16.3.1",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PancrePal-xiaoyibao/mcp-pubmed-server-pancrpal.git"
  }
}
